{
  "name": "room-vj",
  "private": true,
  "version": "0.1.0",
  "description": "Browser-based live room visuals that react to music, people, and synced nearby devices.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm-run-all typecheck clean:pages build:site copy:404",
    "build:site": "vite build",
    "clean:pages": "node scripts/clean-pages-build.mjs",
    "copy:404": "node scripts/copy-404.mjs",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "smoke": "bash scripts/smoke.sh",
    "preview": "vite preview --host 127.0.0.1 --port 4173"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "@tanstack/react-query": "^5.100.9",
    "lucide-react": "^1.14.0",
    "meyda": "^5.6.3",
    "peerjs": "^1.5.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@webgpu/types": "^0.1.68",
    "@webgpu/types": "^0.1.69",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.6",
    "npm-run-all2": "^8.0.4",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
